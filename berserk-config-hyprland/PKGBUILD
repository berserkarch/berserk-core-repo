# Maintainer: Gaurav Raj (@thehackersbrain) <gaurav@thehackersbrain.dev>

pkgname=berserk-config-hyprland
pkgver=0.1.0
pkgrel=4
pkgdesc="Default Hyprlandconfiguration for Berserk Arch"
arch=('any')
url="https://github.com/thehackersbrain/berserk-config-hyprland"
license=('GPL3')
depends=('hyprland' 'sddm' 'waybar' 'rofi-wayland' 'swww' 'xclip' 'wl-clipboard' 'xdotool' 'qt5ct' 'qt6ct' 'kvantum' 'xdg-desktop-portal-gtk' 'xdg-desktop-portal-hyprland' 'plasma-integration' 'hyprland-qt-support' 'hyprqt6engine' 'hyprpolkitagent' 'cliphist' 'dunst')

source=()
sha256sums=()

install="$pkgname.install"
berserkconfig="usr/share/berserkarch"

package() {
  install -d "${pkgdir}/etc/skel/.config"
  install -d "${pkgdir}/${berserkconfig}/scripts"

  cp -r "${startdir}/config/user/dunst" "${pkgdir}/etc/skel/.config/"
  cp -r "${startdir}/config/user/hypr" "${pkgdir}/etc/skel/.config/"
  cp -r "${startdir}/config/user/qt5ct" "${pkgdir}/etc/skel/.config/"
  cp -r "${startdir}/config/user/qt6ct" "${pkgdir}/etc/skel/.config/"
  cp -r "${startdir}/config/user/waybar" "${pkgdir}/etc/skel/.config/"
  cp -r "${startdir}/config/scripts" "${pkgdir}/${berserkconfig}/"
  install -Dm644 ${startdir}/config/environment "${pkgdir}/etc/environment.new"
}
