# Maintainer: Gaurav Raj (@thehackersbrain) <gaurav@thehackersbrain.dev>

pkgname=berserk-keyring
pkgver=0.1.1
pkgrel=1
pkgdesc="The GPG keyring for the berserkarch-core repository"
arch=('any')
url="https://github.com/berserkarch/berserk-core/tree/main/berserk-keyring"
license=('GPL3')
depends=('archlinux-keyring')
makedepends=('gnupg')
install=berserk-keyring.install

package() {
  install -Dm0644 "${srcdir}/../berserkarch.gpg" \
    "${pkgdir}/usr/share/pacman/keyrings/berserkarch.gpg"

  install -Dm0644 "${srcdir}/../berserkarch-trusted" \
    "${pkgdir}/usr/share/pacman/keyrings/berserkarch-trusted"

  install -Dm0644 "${srcdir}/../berserkarch-revoked" \
    "${pkgdir}/usr/share/pacman/keyrings/berserkarch-revoked"
}
